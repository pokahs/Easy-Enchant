{
	"schemaVersion": 1,
	"id": "easyenchant",
	"version": "${version}",
	"name": "Easy Enchant",
	"description": "Easily and efficiently combine your gear with books at anvils!",
	"authors": [
		"pokahs"
	],
	"contact": {
		"sources": "https://github.com/pokahs/Easy-Enchant",
		"issues": "https://github.com/pokahs/Easy-Enchant/issues"
	},
	"license": "MIT",
	"icon": "assets/easyenchant/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"io.github.pokahs.easyenchant.EasyEnchant"
		],
		"client": [
			"io.github.pokahs.easyenchant.EasyEnchantClient"
		],
		"modmenu": [
			"io.github.pokahs.easyenchant.ModMenuIntegration"
		]
	},
	"mixins": [
		{
			"config": "easyenchant.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.17.2",
		"minecraft": ["~1.21.6", "~1.21.7", "~1.21.8"],
		"java": ">=21",
		"fabric-api": "*",
		"cloth-config": "*",
		"modmenu": "*"
	}
}